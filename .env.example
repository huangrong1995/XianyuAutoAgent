# ===========================================
# 闲鱼自动托管工具 - 环境配置
# ===========================================

# -------- 必需配置 --------

# 闲鱼 Cookies（从网页端获取）
COOKIES_STR=your_cookies_here

# 百炼 API Key（百炼/通义千问平台获取，用于远程模式）
API_KEY=your_api_key_here

# -------- 模型配置 --------

# 远程模型 API 地址（百炼）
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 远程模型名称（qwen-max / qwen-plus / gpt-4 等）
MODEL_NAME=qwen-max

# -------- 本地模型配置（优先使用，免费）--------
# 默认启用本地模型，自动检测 Ollama 是否可用
# 不可用时自动切换到远程百炼模型

# 是否启用本地模型（True/False）
USE_LOCAL_MODEL=True

# 本地 Ollama API 地址
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1

# 本地模型名称（7~9B 推荐 qwen2.5:7b / deepseek-llm:8b）
LOCAL_MODEL_NAME=qwen2.5:7b

# -------- 可选配置 --------

# 人工接管切换关键词（默认句号，输入句号切换人工/AI）
TOGGLE_KEYWORDS=。

# 是否模拟人工打字延迟（True/False）
SIMULATE_HUMAN_TYPING=False
